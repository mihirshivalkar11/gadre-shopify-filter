<!-- ═══ Delivery Message Banner ═══ -->
<div id="gadre-delivery-banner" class="gadre-delivery-banner"></div>

<!-- ═══ Empty State (shown when no products match the depot) ═══ -->
<div id="gadre-empty-state" class="gadre-empty-state">
  <div class="gadre-empty-icon">🐟</div>
  <p class="gadre-empty-title">No products available for your location</p>
  <p class="gadre-empty-subtitle">Try a different pincode to see what's available near you.</p>
  <button class="gadre-change-btn" onclick="window.GadreFilter && window.GadreFilter.showModal()">
    Change Location
  </button>
</div>
